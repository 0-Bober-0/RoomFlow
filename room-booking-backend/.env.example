# Local PostgreSQL
POSTGRES_DB=coworking_booking
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking

# Spring datasource. For Docker Compose app container use host `postgres`.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/coworking_booking
SPRING_DATASOURCE_USERNAME=booking
SPRING_DATASOURCE_PASSWORD=booking

# Redis. For Docker Compose app container use host `redis`.
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# Security
JWT_SECRET=replace-with-random-string-at-least-32-bytes-long
JWT_EXPIRATION=PT24H
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Demo seed
SEED_ENABLED=true
ADMIN_EMAIL=admin@coworking.local
ADMIN_PASSWORD=Admin12345!
